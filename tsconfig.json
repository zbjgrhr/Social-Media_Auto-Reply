{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["chrome"],
    "paths": {
      "@core/*": ["./packages/core/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "packages/core/src/**/*.ts"]
}
